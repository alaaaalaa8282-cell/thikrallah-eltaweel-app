<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D4A28">

    <ScrollView
        android:id="@+id/container_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_my_athkar"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/my_athkar"
                    android:text="@string/my_athkar"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

                <Button
                    android:id="@+id/button_morning_thikr"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/sun"
                    android:text="@string/morningThikr"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_night_thikr"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/moon"
                    android:text="@string/nightThikr"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

                <Button
                    android:id="@+id/button_quran"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/quran"
                    android:text="@string/quranic_verses"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

            </LinearLayout>

            <!-- Row 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_athan"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/athan"
                    android:text="@string/athan"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

                <Button
                    android:id="@+id/button_qibla"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/qibla"
                    android:text="@string/qibla"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

            </LinearLayout>

            <!-- Row 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/hisn_almuslim"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/hisn_almuslim"
                    android:text="@string/hisn_almuslim"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

                <Button
                    android:id="@+id/button_settings"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/card_bg"
                    android:drawableTop="@drawable/settings"
                    android:text="@string/Settings"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="10dp" />

            </LinearLayout>

            <!-- Row 5 - زر انشر الخير كامل العرض -->
            <Button
                android:id="@+id/button_sadaqa"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                android:background="@drawable/card_bg"
                android:drawableTop="@drawable/share_button"
                android:text="@string/sadaqa"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="10dp" />

        </LinearLayout>
    </ScrollView>
</RelativeLayout>
