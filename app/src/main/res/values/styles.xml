<resources>

    <style name="AppBaseTheme" parent="Theme.AppCompat">
    </style>

    <style name="AppTheme" parent="AppBaseTheme">
        <item name="android:windowBackground">#0D4A28</item>
    </style>

    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">4dp</item>
        <item name="android:minHeight">1px</item>
        <item name="android:background">?android:attr/listDivider</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:layout_marginBottom">4dp</item>
    </style>

    <style name="AppTheme.Base" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">#1B6B3A</item>
        <item name="colorPrimaryDark">#0D4A28</item>
        <item name="colorAccent">#4CAF50</item>
        <item name="android:windowBackground">#0D4A28</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#B2DFDB</item>
        <item name="windowActionBarOverlay">true</item>
    </style>

    <style name="AppTheme.Preference" parent="AppTheme.Base">
        <item name="windowActionBarOverlay">true</item>
    </style>

    <style name="TitleText">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/title_color</item>
        <item name="android:lines">1</item>
        <item name="android:maxLines">1</item>
    </style>

    <style name="ToolBarArea" />

    <style name="NotificationText"
        parent="android:TextAppearance.StatusBar.EventContent" />

    <style name="NotificationTitle"
        parent="android:TextAppearance.StatusBar.EventContent.Title" />

    <style name="TranslationText">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TranslationText.Highlighted">
        <item name="android:textColor">@color/translation_highlight</item>
    </style>

    <style name="TranslationText.NightMode">
        <item name="android:background">#0D4A28</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="TranslationText.NightMode.Highlighted">
        <item name="android:textColor">@color/translation_highlight</item>
    </style>

    <style name="PageTypeTitle">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PageTypeDescription">
        <item name="android:textColor">#B2DFDB</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="SearchResult">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="SearchResult.Location">
        <item name="android:textColor">#B2DFDB</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="PanelLabel">
        <item name="android:textColor">@color/panel_label</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="SherlockDropDownItem">
        <item name="android:textAppearance">@style/SherlockDropDownItemText</item>
        <item name="android:paddingLeft">8dp</item>
        <item name="android:paddingRight">8dp</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="SherlockDropDownItemText">
        <item name="android:textColor">@color/sherlock_primary_text_disable</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="SherlockSpinnerItem">
        <item name="android:textAppearance">@style/SherlockSpinnerItemText</item>
        <item name="android:paddingLeft">8dp</item>
        <item name="android:paddingRight">8dp</item>
    </style>

    <style name="SherlockSpinnerItemText">
        <item name="android:textColor">@color/sherlock_primary_text</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
    </style>

</resources>
